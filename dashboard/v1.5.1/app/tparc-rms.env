# TP-ARC RMS runtime configuration.
#
# Edit this file on the Raspberry Pi, then restart:
#   sudo systemctl restart tparc-rms

TPARC_ALLOW_INSECURE_DEV=1
TPARC_HOST=0.0.0.0
TPARC_PORT=5000
TPARC_SERIAL_BAUD=115200
TPARC_SESSION_MINUTES=30
TPARC_RMS_KILL_ENABLED=0
TPARC_OPEN_BROWSER=0
TPARC_AUTO_INSTALL=0

# Leave unset to auto-detect common Linux serial devices.
# Example:
# TPARC_SERIAL_PORT=/dev/ttyACM0

TPARC_SINGLE_RUNTIME=/var/lib/tparc-rms/runtime
TPARC_DB=/var/lib/tparc-rms/tparc.sqlite3

# Arduino firmware upload from the admin Firmware page.
TPARC_ARDUINO_CLI=arduino-cli
TPARC_ARDUINO_DEFAULT_FQBN=arduino:avr:uno
TPARC_FIRMWARE_UPLOAD_DIR=/var/lib/tparc-rms/firmware
TPARC_FIRMWARE_TIMEOUT=600
TPARC_FIRMWARE_MAX_MB=8

# GitHub updater. Releases are preferred; source path is the repo-folder scan root.
TPARC_UPDATE_REPO=xav200405/Project-HORIZON
TPARC_UPDATE_ASSET_PATTERN=^tparc-rms-pi-app-.*\.tar\.gz$
TPARC_UPDATE_SOURCE_PATH=dashboard
