void handleTelemetry() {
  uint32_t now = millis();

  if ((uint32_t)(now - telemetryTimer) >= TELEMETRY_INTERVAL_MS) {
    printTelemetryJson();
    telemetryTimer = now;
  }
}

void adjustGain(float &gain, char dir, float step, float minVal, float maxVal) {
  if (dir == '+') gain += step;
  if (dir == '-') gain -= step;
  gain = constrainFloat(gain, minVal, maxVal);
}

void printGains() {
  Serial.print(F("PID gains | Roll P/I/D="));
  Serial.print(pid_p_gain_roll, 2);
  Serial.print('/');
  Serial.print(pid_i_gain_roll, 3);
  Serial.print('/');
  Serial.print(pid_d_gain_roll, 2);

  Serial.print(F(" | Pitch P/I/D="));
  Serial.print(pid_p_gain_pitch, 2);
  Serial.print('/');
  Serial.print(pid_i_gain_pitch, 3);
  Serial.print('/');
  Serial.print(pid_d_gain_pitch, 2);

  Serial.print(F(" | Yaw P/I/D="));
  Serial.print(pid_p_gain_yaw, 2);
  Serial.print('/');
  Serial.print(pid_i_gain_yaw, 3);
  Serial.print('/');
  Serial.print(pid_d_gain_yaw, 2);

  Serial.println();
}

/*
  Serial PID tuning command map for WMS_v3.2:
    r+/r- = Roll P  +/- 0.01
    i+/i- = Roll I  +/- 0.01
    d+/d- = Roll D  +/- 0.01

    R+/R- = Pitch P +/- 0.01
    I+/I- = Pitch I +/- 0.01
    D+/D- = Pitch D +/- 0.01

    y+/y- = Yaw P   +/- 0.01
    u+/u- = Yaw I   +/- 0.01
    Y+/Y- = Yaw D   +/- 0.01

    ? = print current gains
*/
void handleSerialTuning() {
  static char pending = 0;
  static char commandBuffer[160];
  static byte commandLen = 0;
  static bool collectingCommand = false;

  while (Serial.available() > 0) {
    char c = Serial.read();

    if (collectingCommand) {
      if (c == '\r') {
        continue;
      }

      if (c == '\n') {
        commandBuffer[commandLen] = '\0';
        handleBatteryCommand(commandBuffer);
        handlePidCommand(commandBuffer);
        commandLen = 0;
        collectingCommand = false;
        continue;
      }

      if (commandLen < sizeof(commandBuffer) - 1) {
        commandBuffer[commandLen++] = c;
      } else {
        commandLen = 0;
        collectingCommand = false;
        Serial.println(F("ERR:SERIAL_LINE_TOO_LONG"));
      }

      continue;
    }

    if (c == 'B' || c == 'P') {
      commandLen = 0;
      commandBuffer[commandLen++] = c;
      collectingCommand = true;
      pending = 0;
      continue;
    }

    if (c == '?') {
      printGains();
      pending = 0;
      continue;
    }

    if (pending == 0) {
      if (c == 'r' || c == 'R' || c == 'y' ||
          c == 'i' || c == 'I' || c == 'u' ||
          c == 'd' || c == 'D' || c == 'Y') {
        pending = c;
      }
    } else {
      if (c == '+' || c == '-') {
        switch (pending) {
          case 'r': adjustGain(pid_p_gain_roll, c, PID_TUNE_STEP, 0.0f, PID_P_GAIN_MAX); break;
          case 'R': adjustGain(pid_p_gain_pitch, c, PID_TUNE_STEP, 0.0f, PID_P_GAIN_MAX); break;
          case 'y': adjustGain(pid_p_gain_yaw, c, PID_TUNE_STEP, 0.0f, PID_P_GAIN_MAX); break;

          case 'i': adjustGain(pid_i_gain_roll, c, PID_TUNE_STEP, 0.0f, PID_I_GAIN_MAX); break;
          case 'I': adjustGain(pid_i_gain_pitch, c, PID_TUNE_STEP, 0.0f, PID_I_GAIN_MAX); break;
          case 'u': adjustGain(pid_i_gain_yaw, c, PID_TUNE_STEP, 0.0f, PID_I_GAIN_MAX); break;

          case 'd': adjustGain(pid_d_gain_roll, c, PID_TUNE_STEP, 0.0f, PID_D_GAIN_MAX); break;
          case 'D': adjustGain(pid_d_gain_pitch, c, PID_TUNE_STEP, 0.0f, PID_D_GAIN_MAX); break;
          case 'Y': adjustGain(pid_d_gain_yaw, c, PID_TUNE_STEP, 0.0f, PID_D_GAIN_MAX); break;
        }

        printGains();
      }

      pending = 0;
    }
  }
}

// ================================================================
// SETUP / MAIN LOOP
// ================================================================

void setup() {
  pinMode(STATUS_LED_PIN, OUTPUT);
  digitalWrite(STATUS_LED_PIN, LOW);
  pinMode(BATTERY_SENSE_PIN, INPUT);

  configureEscPins();
  forceMotorsOff();

  Serial.begin(SERIAL_BAUD);
  delay(300);

  Serial.print(F("YMFC Flight Controller V6.6C_QMC5883P_COMPASS "));
  Serial.print(FIRMWARE_VERSION);
  Serial.print(F(" "));
  Serial.print(FIRMWARE_REVISION);
  Serial.println(F(" starting..."));

  Wire.begin();
  TWBR = 12; // 400 kHz I2C on 16 MHz Arduino Uno.
  Wire.setClock(I2C_SPEED);

  loadCalibrationFromEEPROM();

  configureReceiverInterrupts();

  if (!setupMPU6050()) {
    sensor_ok = false;
    Serial.println(F("ERROR: MPU6050 not responding at 0x68."));
  } else {
    sensor_ok = true;
    calibrateGyroAtBootIfNeeded();
  }

  // Compass is optional / non-fatal by request.
  // If it fails, the UAV continues with normal roll/pitch stabilization and yaw-rate behavior.
  if (!setupCompass()) {
    Serial.println(F("WARNING: Compass init failed at 0x2C. Continuing without heading hold."));
  } else {
    Serial.println(F("Compass OK at 0x2C. Heading hold available when yaw stick is centered."));
  }

  // Barometer is optional / telemetry-only. It does not block arming or control.
  if (!setupBarometer()) {
    Serial.println(F("WARNING: BMP280/BME280 init failed at 0x76. Continuing without barometer telemetry."));
  } else {
    Serial.println(F("Barometer OK at 0x76. Pressure and relative altitude telemetry active."));
    updateBarometer();
  }

  forceMotorsOff();
  writeEscPulses();
  updateBatteryMonitor();

  telemetryTimer = millis();
  ledTimer = millis();
  lastImuMicros = micros();

  Serial.println(F("Startup complete. Waiting for valid receiver, CH6 safe, throttle low."));
}

void loop() {
  loop_timer = micros();

  copyAndCalibrateReceiver();
  updateFlightModeCap();
  updateBatteryMonitor();

  if (sensor_ok && gyro_calibrated) {
    updateAngles();
  }

  updateCompass();
  updateBarometer();

  check_safety_and_arming();

  if (flight_mode == FLIGHT_ARMED) {
    calculate_pid();
    mixMotors();
  } else {
    forceMotorsOff();
    resetPID();
  }

  updateStatusLED(getLedState());

  writeEscPulses();

  handleSerialTuning();
  handleTelemetry();

  uint32_t elapsed = micros() - loop_timer;

  if (elapsed > LOOP_TIME_US) {
    // This reports on the next telemetry/LED cycle.
    loopOverrun = true;
  } else {
    loopOverrun = false;

    while ((uint32_t)(micros() - loop_timer) < LOOP_TIME_US) {
      // 250 Hz sync.
    }
  }
}
