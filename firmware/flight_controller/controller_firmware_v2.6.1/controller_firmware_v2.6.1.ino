  uint8_t version;         // EEPROM_VERSION

  uint16_t rxCenter[6];
  uint16_t rxMin[6];
  uint16_t rxMax[6];

  // +1 means requested positive movement increases PWM from center.
  // -1 means requested positive movement decreases PWM from center.
  // Positive movements:
  //   roll right, pitch/nose up, yaw right, throttle high.
  int8_t rollDir;
  int8_t pitchDir;
  int8_t yawDir;
  int8_t throttleDir;

  // Semantic switch positions captured by setup.
  uint16_t ch5Up;
  uint16_t ch5Mid;
  uint16_t ch5Down;
  uint16_t ch6On;
  uint16_t ch6Off;

  // MPU6050 gyro zero offsets, raw ADC counts.
  int16_t gyroOffset[3];   // X, Y, Z

  // Stationary compass baseline/offset, raw counts.
  int16_t magBaseline[3];
  uint16_t magAvgDiffX100[3];
  uint16_t magMaxStepDiff[3];

  // BMP280 raw pressure baseline/offset.
  int32_t baroBaselineRaw;
  uint16_t baroAvgDiffX100;
  uint16_t baroMaxStepDiff;

  uint8_t sensorFlags;

  uint16_t checksum;       // Must remain last.
